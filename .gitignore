!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.ico

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
